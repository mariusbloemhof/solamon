{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solamon.example/schemas/device-profile-1.0.json",
  "title": "Solamon Device Profile",
  "description": "Schema every device profile YAML file conforms to. Spec: docs/specs/device-library/profile-schema.md. MVP scope is Modbus profiles (TCP and RTU). MQTT-push and HTTP-push profiles are out of MVP scope and will require a discriminated extension to this schema (see SOL-22).",
  "type": "object",
  "required": ["schema_version", "device", "connection", "fingerprint", "read_blocks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Profile schema version (semver, major.minor)."
    },
    "device": {
      "type": "object",
      "required": ["manufacturer", "model", "category"],
      "additionalProperties": false,
      "properties": {
        "manufacturer": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["meter", "pv_inverter", "bess_pcs", "bess_hub", "generator", "ppc", "gateway"]
        }
      }
    },
    "connection": {
      "type": "object",
      "required": ["protocol"],
      "additionalProperties": false,
      "properties": {
        "protocol": {
          "type": "string",
          "enum": ["modbus_tcp", "modbus_rtu"],
          "description": "MVP: Modbus only. mqtt and http_push protocols are deferred (see SOL-22)."
        },
        "default_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "default_unit_id": { "type": "integer", "minimum": 0, "maximum": 247 }
      }
    },
    "fingerprint": {
      "type": "object",
      "required": ["reads"],
      "additionalProperties": false,
      "properties": {
        "reads": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/FingerprintRead" }
        },
        "identifiers": {
          "type": "array",
          "items": { "$ref": "#/$defs/Identifier" }
        }
      }
    },
    "read_blocks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ReadBlock" }
    },
    "control": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/ControlSpec" }
    }
  },
  "$defs": {
    "FormatType": {
      "type": "string",
      "description": "Generic format types are decoded by the profile loader directly. Use 'custom' + 'decoder: <name>' for vendor-specific decoders registered with the loader (see profile-schema.md §6).",
      "enum": [
        "float32_be",
        "float32_le",
        "float32_mb",
        "uint16",
        "int16",
        "uint32_be",
        "int32_be",
        "dword_high_first",
        "word",
        "ascii",
        "custom"
      ]
    },
    "FingerprintRead": {
      "type": "object",
      "required": ["address", "length"],
      "additionalProperties": false,
      "properties": {
        "address": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 125,
          "description": "Length in 16-bit registers (each 2 bytes)."
        },
        "format": { "$ref": "#/$defs/FormatType" },
        "expected": {},
        "expected_range": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "expected_contains": { "type": "string" },
        "expect_exception": {
          "type": "integer",
          "enum": [1, 2, 3, 4]
        }
      },
      "oneOf": [
        { "required": ["expected"] },
        { "required": ["expected_range"] },
        { "required": ["expected_contains"] },
        { "required": ["expect_exception"] }
      ],
      "allOf": [
        {
          "if": { "not": { "required": ["expect_exception"] } },
          "then": { "required": ["format"] }
        },
        {
          "if": { "required": ["expected_contains"] },
          "then": {
            "properties": {
              "format": { "const": "ascii" }
            },
            "required": ["format"]
          }
        }
      ]
    },
    "Identifier": {
      "type": "object",
      "required": ["logical", "address", "length", "format"],
      "additionalProperties": false,
      "properties": {
        "logical": { "type": "string", "minLength": 1 },
        "address": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 125,
          "description": "Length in 16-bit registers."
        },
        "format": { "$ref": "#/$defs/FormatType" },
        "decoder": {
          "type": "string",
          "description": "Required when format is 'custom'."
        },
        "expected_contains": { "type": "string" }
      },
      "if": {
        "properties": { "format": { "const": "custom" } },
        "required": ["format"]
      },
      "then": {
        "required": ["decoder"]
      }
    },
    "ReadBlock": {
      "type": "object",
      "required": ["name", "fc", "address", "length", "cadence_s", "metrics"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Block identifier; used in MQTT payload `block` field."
        },
        "fc": {
          "type": "integer",
          "enum": [3, 4],
          "description": "Modbus function code: 3=read holding registers, 4=read input registers."
        },
        "address": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 125,
          "description": "Number of registers (each 2 bytes). Max 125 per Modbus FC03 spec."
        },
        "cadence_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "description": "Poll interval in seconds. MVP storage cadence equals poll cadence."
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/MetricMapping" }
        }
      }
    },
    "MetricMapping": {
      "type": "object",
      "required": ["logical", "offset", "format"],
      "additionalProperties": false,
      "properties": {
        "logical": {
          "type": "string",
          "minLength": 1,
          "description": "Must reference a key in the logical metric catalog."
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "description": "Byte offset within the FC03 response payload. Loader enforces format-appropriate alignment (e.g., float32 offsets must be multiples of 4)."
        },
        "format": { "$ref": "#/$defs/FormatType" },
        "decoder": {
          "type": "string",
          "description": "Required when format is 'custom'. Names a decoder registered with the profile loader."
        },
        "scale": {
          "type": "number",
          "default": 1.0,
          "description": "Final value = raw × scale. Use to normalise device units to catalog units (e.g. 0.001 for W→kW)."
        },
        "sign": {
          "type": "string",
          "enum": ["signed", "unsigned"]
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "description": "Length in 16-bit registers (each 2 bytes). Only meaningful for variable-length formats (e.g. ascii). Default depends on format."
        },
        "aliased": {
          "type": "boolean",
          "default": false,
          "description": "True if this metric deliberately shares an offset with another (e.g. legacy alias)."
        }
      },
      "if": {
        "properties": { "format": { "const": "custom" } }
      },
      "then": {
        "required": ["decoder"]
      }
    },
    "ControlSpec": {
      "type": "object",
      "required": ["fc", "address", "format"],
      "additionalProperties": false,
      "properties": {
        "fc": {
          "type": "integer",
          "enum": [6, 16],
          "description": "Modbus function code: 6=write single register, 16=write multiple."
        },
        "address": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "format": { "$ref": "#/$defs/FormatType" },
        "allowed_values": {
          "type": "array",
          "description": "Override the catalog's allowed_values for this profile."
        },
        "readback_register": {
          "type": "object",
          "required": ["address", "format"],
          "additionalProperties": false,
          "properties": {
            "address": { "type": "integer", "minimum": 0, "maximum": 65535 },
            "offset": { "type": "integer", "minimum": 0, "default": 0 },
            "fc": {
              "type": "integer",
              "enum": [3, 4],
              "default": 3,
              "description": "Modbus function code for read-back: 3=read holding registers (default), 4=read input registers. Only matters for devices that put a writable register in input-register space."
            },
            "format": { "$ref": "#/$defs/FormatType" },
            "length": {
              "type": "integer",
              "minimum": 1,
              "description": "Length in 16-bit registers."
            }
          }
        },
        "readback_delay_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 500,
          "description": "Wait between FC06 write and the verifying FC03 read."
        }
      }
    }
  }
}
